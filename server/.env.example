# Server
PORT=3001
CLIENT_ORIGINS=http://localhost:5173

# Supabase (Step 2) — Project Settings → API Keys
# Use the PUBLISHABLE key (sb_publishable_...). The secret key is NOT used —
# the server runs queries as the authenticated user so RLS enforces ownership.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Anthropic (Step 6)
ANTHROPIC_API_KEY=

# AI cost controls
AI_ENABLED=true
# Optional comma-separated allowlist. Leave blank to allow every signed-in user.
AI_ALLOWED_EMAILS=
AI_DAILY_USER_LIMIT=5
AI_HOURLY_USER_LIMIT=2
AI_COOLDOWN_SECONDS=30
AI_MAX_JOB_DESCRIPTION_CHARS=8000
AI_MAX_OUTPUT_TOKENS=900
AI_CACHE_TTL_HOURS=168
